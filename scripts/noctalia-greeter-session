#!/usr/bin/env sh
set -eu

GREETER_BIN="${NOCTALIA_GREETER_BIN:-/usr/local/bin/noctalia-greeter}"

# Distro-agnostic runtime dir fallback for environments where PAM session
# modules don't create /run/user/<uid>.
if [ -z "${XDG_RUNTIME_DIR:-}" ] || [ ! -d "${XDG_RUNTIME_DIR}" ] || [ ! -w "${XDG_RUNTIME_DIR}" ]; then
  XDG_RUNTIME_DIR="/tmp/noctalia-runtime-$(id -u)"
  export XDG_RUNTIME_DIR
  mkdir -p "${XDG_RUNTIME_DIR}"
  chmod 700 "${XDG_RUNTIME_DIR}" || true
fi

unset WAYLAND_DISPLAY
if command -v dbus-run-session >/dev/null 2>&1; then
  exec dbus-run-session -- cage -s -- "${GREETER_BIN}"
fi

echo "warn: dbus-run-session not found; starting cage without a session bus." >&2
exec cage -s -- "${GREETER_BIN}"
